<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hudRoot"
    android:layout_width="224dp"
    android:layout_height="wrap_content"
    android:background="#E6000000"
    android:orientation="vertical"
    android:padding="5dp">

    <TextView
        android:id="@+id/hudIntentText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="ACTIVE_ANALYSIS · READY"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/hudDetailText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="BROWSING_LIST · c=0.94"
        android:textColor="#DDFFFFFF"
        android:textSize="8sp" />

    <TextView
        android:id="@+id/hudObserverText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="4"
        android:text="obs=IDLE"
        android:textColor="#80CBC4"
        android:textSize="7sp" />
</LinearLayout>
