<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Aether Dev Overlay (Stub-Driven Development - Compose UI) -->
        <service
            android:name="com.aethermind.ui.AetherDevOverlayService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Phase 2 execution dispatcher service. Fully-qualified name is required because
             this class is in com.aethermind.execution while app namespace is com.aether.renderer.
             Old com.aether.renderer.accessibility.AetherAccessibilityService removed: conflict fix. -->
        <service
            android:name="com.aethermind.execution.AetherAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/aether_accessibility_service" />
        </service>

    </application>
</manifest>
